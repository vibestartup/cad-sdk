{
  "name": "@vibestartup/cad",
  "version": "0.1.0",
  "description": "declarative parametric CAD primitives for vibestartup. studio, sketch, extrude, revolve, fillet, boolean, material, import, link.",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/vibestartup/cad-sdk.git" },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./printer": "./src/printer.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./printer": { "types": "./dist/printer.d.ts", "import": "./dist/printer.js" }
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vibestartup/thing": "workspace:*",
    "@vibestartup/sdk-runtime": "workspace:*"
  },
  "peerDependencies": { "react": "^18.2.0 || ^19.0.0" },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
